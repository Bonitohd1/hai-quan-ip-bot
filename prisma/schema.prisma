// Prisma schema - v5 compatible (SQLite for local/Vercel ephemeral)
// Production falls back to lib/documents.json when DB is empty

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Document model for storing uploaded PDFs
model Document {
  id          String   @id @default(uuid())
  code        String   @unique
  date        String   // Format: DDMMYYYY (e.g., 16092025)
  name        String
  filename    String   @unique
  type        String   // e.g., "Gia han", "Cap moi"
  description String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@index([name])
  @@index([type])
}

// Admin user for authentication
model AdminUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  email     String?  @unique
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Activity log for tracking document uploads and operations
model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  resource   String
  resourceId String
  details    String?
  ipAddress  String?
  userAgent  String?

  createdAt  DateTime @default(now())

  @@index([action])
  @@index([resourceId])
  @@index([createdAt])
}
