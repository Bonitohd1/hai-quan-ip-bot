// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
}

// Document model for storing uploaded PDFs
model Document {
  id          String   @id @default(uuid())
  code        String   @unique
  date        String   // Format: DDMMYYYY (e.g., 16092025)
  name        String
  filename    String   @unique
  type        String   // e.g., "Gia hạn", "Cấp mới"
  description String
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([code])
  @@index([name])
  @@index([type])
}

// Admin user for authentication (legacy)
model AdminUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  email     String?  @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Extended user profile (linked to Google OAuth by email)
// role values: "VIEWER" | "OFFICER" | "ADMIN"
model UserProfile {
  id            String   @id @default(cuid())
  email         String   @unique

  // Thông tin cá nhân
  fullName      String?
  employeeId    String?  @unique
  avatarUrl     String?

  // Thông tin công tác
  unit          String?   // Cục/Chi cục
  department    String?   // Phòng ban
  position      String?   // Chức vụ
  phoneInternal String?   // Số nội bộ

  // Phân quyền & trạng thái (VIEWER | OFFICER | ADMIN)
  role          String   @default("VIEWER")
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastLoginAt   DateTime?

  @@index([email])
  @@index([role])
}

// Activity log for tracking document uploads and operations
model ActivityLog {
  id        String   @id @default(cuid())
  action    String   // e.g., "UPLOAD", "DELETE", "VIEW", "DOWNLOAD"
  resource  String   // e.g., "document", "user"
  resourceId String
  details   String?  // JSON stringified details
  ipAddress String?
  userAgent String?
  
  createdAt DateTime @default(now())
  
  @@index([action])
  @@index([resourceId])
  @@index([createdAt])
}
